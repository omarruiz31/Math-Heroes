  dialogue:
    lines:
    - characterName: "Maestro de la Divisi\xF3n"
      sentence: "\xA1Hola! Has llegado a Ciudad Divisi\xF3n. Aqu\xED aprendemos a
        repartir de forma justa."
      characterPortrait: {fileID: 21300000, guid: f7155fac0d464a04796941cd3fbbfaac,
        type: 3}
    - characterName: "Maestro de la Divisi\xF3n"
      sentence: "Para llegar al castillo, debes resolver las divisiones de los enemigos
        que custodian las calles. \xA1Comienza con el nivel 1!"
      characterPortrait: {fileID: 21300000, guid: f7155fac0d464a04796941cd3fbbfaac,
        type: 3}
