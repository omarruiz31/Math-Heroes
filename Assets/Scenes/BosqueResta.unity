  dialogue:
    lines:
    - characterName: "Gu\xEDa del Bosque"
      sentence: "\xA1Saludos! Te encuentras en el Bosque Resta. Ten cuidado, aqu\xED
        las cosas disminuyen si no eres r\xE1pido."
      characterPortrait: {fileID: 21300000, guid: f7155fac0d464a04796941cd3fbbfaac,
        type: 3}
    - characterName: "Gu\xEDa del Bosque"
      sentence: "Tu misi\xF3n es despejar el bosque resolviendo las restas de los
        monstruos. \xA1Vence al nivel 1 para abrir el sendero!"
      characterPortrait: {fileID: 21300000, guid: f7155fac0d464a04796941cd3fbbfaac,
        type: 3}
